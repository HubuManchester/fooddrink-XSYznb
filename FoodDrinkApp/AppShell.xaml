<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FoodDrinkApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FoodDrinkApp"
    Title="NutriBite"
    FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{AppThemeBinding Light=#F8F6F3, Dark=#1C1C1E}"
    Shell.ForegroundColor="{AppThemeBinding Light=#2C2E2D, Dark=#FFF2DF}"
    Shell.TitleColor="{AppThemeBinding Light=#2C2E2D, Dark=#FFF2DF}"
    Shell.UnselectedColor="{AppThemeBinding Light=#B4B8B6, Dark=#BFA58E}"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=#F8F6F3, Dark=#120E0B}"
    Shell.TabBarForegroundColor="{AppThemeBinding Light=#4CAF79, Dark=#FFB347}"
    Shell.TabBarTitleColor="{AppThemeBinding Light=#4CAF79, Dark=#FFB347}"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light=#B4B8B6, Dark=#98989E}">

    <TabBar>
        <ShellContent
            Title="Foods"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
        <ShellContent
            Title="Hardware"
            ContentTemplate="{DataTemplate local:HardwarePage}"
            Route="HardwarePage" />
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>
</Shell>
